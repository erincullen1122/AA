#!/usr/bin/env bash
set -euo pipefail

if [[ "${AA_SKIP_AUTO_PUSH:-}" == "1" ]]; then
  exit 0
fi

branch_name="$(git branch --show-current)"

if [[ -z "${branch_name}" ]]; then
  exit 0
fi

if git rev-parse --abbrev-ref --symbolic-full-name "@{u}" >/dev/null 2>&1; then
  git push
else
  git push -u origin "${branch_name}"
fi