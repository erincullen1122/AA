{
  "name": "aa-workshop-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:banner": "mkdir -p public && cp -f banner.jpg public/banner.jpg",
    "predev": "npm run sync:banner",
    "prebuild": "npm run sync:banner",
    "dev": "VITE_BUILD_TS=$(date +%s) vite",
    "build": "VITE_BUILD_TS=$(date +%s) vite build",
    "preview": "vite preview",
    "check": "npm run build",
    "deploy:prod": "npm run check && npx vercel --prod --yes --scope anniehall16-1319s-projects"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^5.4.21"
  }
}
