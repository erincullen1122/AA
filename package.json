{
  "name": "aa-workshop-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:banner": "mkdir -p public",
    "checkpoint": "bash scripts/checkpoint.sh",
    "verify:sync": "bash scripts/verify-sync.sh",
    "checkpoint:watch": "bash scripts/checkpoint-watch.sh",
    "checkpoint:watch:10": "bash scripts/checkpoint-watch.sh 10",
    "sync:auto:on": "bash scripts/install-hooks.sh",
    "sync:auto:off": "git config --unset core.hooksPath || true",
    "predev": "npm run sync:banner",
    "prebuild": "npm run sync:banner",
    "dev": "VITE_BUILD_TS=$(date +%s) vite",
    "build": "VITE_BUILD_TS=$(date +%s) vite build",
    "preview": "vite preview",
    "check": "npm run build",
    "deploy:prod": "bash scripts/deploy-prod.sh"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^5.4.21"
  }
}
